# Mailtrap configuration for the Contact Me form
# Copy this file to `.env.local` and fill in the real values.

# API token from Mailtrap → Sending Domains → Integration → API/SMTP (or Email Testing for sandbox).
MAILTRAP_API_TOKEN=

# The "from" address. On Mailtrap's free tier you can use the provided demo domain,
# e.g. hello@demomailtrap.com — it must belong to a domain you've added in Mailtrap.
MAILTRAP_SENDER_EMAIL=hello@demomailtrap.com
MAILTRAP_SENDER_NAME=Portfolio Contact Form

# Where contact-form submissions are delivered. This is the value you switch
# from your own email (for testing) to the owner's email (for production).
CONTACT_RECIPIENT_EMAIL=

# Optional: set to "true" to send through Mailtrap's sandbox (Email Testing) inbox
# instead of really delivering. Requires MAILTRAP_TEST_INBOX_ID when enabled.
MAILTRAP_SANDBOX=false
MAILTRAP_TEST_INBOX_ID=

# --- Site / domain configuration (used for metadata, sitemap, robots) ---
# Leave this EMPTY to automatically use the free Vercel domain (e.g.
# your-project.vercel.app) for the demo. Once the owner's custom domain is
# approved and added in Vercel, set this to it and redeploy — no code change.
#   e.g. NEXT_PUBLIC_SITE_URL=https://anahitamouni.com
NEXT_PUBLIC_SITE_URL=
